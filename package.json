{
  "name": "@quickerhub/everything-mcp",
  "version": "0.2.1",
  "description": "MCP server for fast cross-project file search via voidtools Everything SDK (Windows)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "everything-mcp": "bin/everything-mcp.js"
  },
  "files": [
    "bin",
    "publish/cli",
    "native/Everything64.dll",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build.ps1 -Publish",
    "smoke-test": "publish/cli/everything-mcp.exe --smoke-test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuickerHub/everything-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "everything",
    "file-search",
    "model-context-protocol",
    "quickerhub",
    "cursor"
  ]
}
